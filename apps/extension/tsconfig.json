{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@dsa-analyzer/shared": ["../../packages/shared/src"],
      "@dsa-analyzer/analyzer": ["../../packages/analyzer/src"]
    }
  },
  "include": ["src/**/*", "manifest.json"],
  "exclude": ["node_modules", "dist"]
}
