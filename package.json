{
  "name": "dsa-code-analyzer",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "description": "DSA Code Analyzer — Chrome Extension + Backend Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/workspaces.mjs build",
    "dev": "node scripts/workspaces.mjs dev",
    "test": "node scripts/workspaces.mjs test",
    "lint": "node scripts/workspaces.mjs lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "type-check": "node scripts/workspaces.mjs type-check",
    "clean": "node scripts/workspaces.mjs clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
